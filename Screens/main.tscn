[sub_resource type="GDScript" id="GDScript_g1wvp"]
script/source = "extends Character
class_name Scholar

func get_knowledge() -> int:
	return $KnowledgeEffect.start_effect(rng.randi_range(1,7))

func get_hubris() -> int:
	return 2

func get_price() -> int:
	return 15

func _to_string():
	return \"scholar\"
"

